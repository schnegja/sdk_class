# --- OpenAI (NOT Azure OpenAI) -------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: system prompt the assistant uses for every conversation.
SYSTEM_PROMPT=You are a friendly, concise assistant.

# --- Local hosting -------------------------------------------------------------
HOST=0.0.0.0
PORT=3978

# When true, the agent runs without Azure Bot authentication (good for local
# testing via Agents Playground or curl). Set to false and provide the
# CONNECTIONS__SERVICE_CONNECTION__SETTINGS__* values below for cloud auth.
ANONYMOUS_AUTH=true

# --- Azure Bot Service (only required when ANONYMOUS_AUTH=false) --------------
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__AUTHTYPE=ClientSecret
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=
